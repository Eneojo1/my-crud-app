// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Users {
  id          Int       @id @default(autoincrement())
  fname       String
  oname       String?
  lname       String
  sex         Sex
  phone       String    @unique
  email       String    @unique

  password  String

  country_id Int?
  state_id   Int?
  lga_id     Int?

  address     String
  role_id     Int
  status_id   Int
  socials     Json?
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  role        Roles      @relation(fields: [role_id], references: [id])
  status      Statuses     @relation(fields: [status_id], references: [id])

  country    Locations? @relation("UserCountry", fields: [country_id], references: [id])
  state      Locations? @relation("UserState", fields: [state_id], references: [id])
  lga        Locations? @relation("UserLga", fields: [lga_id], references: [id])
  
  posts       Posts[]
  comments    Comments[]
  shares      Shares[]
  reactions   Reactions[]
}

enum Sex {
  Male
  Female
}

model Posts {
  id         Int       @id @default(autoincrement())
  user_id    Int
  category   String
  title      String
  text       String
  published  Boolean    @default(false)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  author     Users      @relation(fields: [user_id], references: [id])
  comments   Comments[]
  shares     Shares[]
  reactions  Reactions[]
}

model Comments {
  id          Int        @id @default(autoincrement())
  user_id     Int?
  guest       String?
  post_id     Int
  parent_id   Int?
  comment     String
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  author      Users?      @relation(fields: [user_id], references: [id])
  post        Posts       @relation(fields: [post_id], references: [id])

  parent      Comments?   @relation("CommentReplies", fields: [parent_id], references: [id])
  replies     Comments[]  @relation("CommentReplies")

  reactions   Reactions[]
}

model Shares {
  id           Int      @id @default(autoincrement())
  user_id      Int?
  guest        String?
  post_id      Int
  times_shared Int      @default(1)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user         Users?   @relation(fields: [user_id], references: [id])
  post         Posts    @relation(fields: [post_id], references: [id])
}

model Reactions {
  id          Int      @id @default(autoincrement())
  user_id     Int?
  guest       String?
  post_id     Int?
  comment_id  Int?
  type        ReactionType
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user        Users?     @relation(fields: [user_id], references: [id])
  post        Posts?     @relation(fields: [post_id], references: [id])
  comment     Comments?  @relation(fields: [comment_id], references: [id])

  @@unique([user_id, guest, post_id, comment_id])
}

enum ReactionType {
  like
  dislike
}

model Media {
  id           Int      @id @default(autoincrement())
  url          String
  type         String
  entity_type  String   // 'post', 'user', 'comment'
  entity_id    Int
  is_thumbnail Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

model Locations {
  id        Int      @id @default(autoincrement())
  name      String

  type      String   // country, state, province, lga, city, etc.

  parent_id Int?
  parent    Locations? @relation("LocationTree", fields: [parent_id], references: [id])

  children  Locations[] @relation("LocationTree")

  country_users Users[] @relation("UserCountry")
  state_users   Users[] @relation("UserState")
  lga_users     Users[] @relation("UserLga")
}

model Roles {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  users       Users[]
}

model Statuses {
  id          Int       @id @default(autoincrement())
  name        String    @unique   // e.g., "active", "inactive", "banned"
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  users       Users[]
}
